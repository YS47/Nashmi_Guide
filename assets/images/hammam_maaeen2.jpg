<script>
var loadCheckResult = null;
loadCheckResult = ((checkFnArgs) =>
        document.getElementById(checkFnArgs[0]) ||
        document.getElementById(checkFnArgs[1]) ||
        document.getElementById(checkFnArgs[2]) ||
        document.getElementById(checkFnArgs[3]))(["esi-gridiron-src","esi-opt-client-src","esi-bellotti-src-skipped","esi-playmaker-src"]);
if (!loadCheckResult) {
  ((fragmentPath) => {
  const error = new Error("ESI fragment " + fragmentPath + " requested, but not found in client");

  if (window.newrelic) {
    console.warn(error);
    // eslint-disable-next-line no-undef
    newrelic.noticeError(error, {
      type: "ESI_LOAD_ERROR",
      fragment: fragmentPath
    });
  } else {
    throw error; // let another monitoring system catch the error.
  }
})('experimentation')
} else if (loadCheckResult.id && loadCheckResult.id.includes && loadCheckResult.id.includes('skipped')) {
  ((fragmentPath) => {
  if (window.newrelic) {
    // eslint-disable-next-line no-undef
    newrelic.addPageAction("ESI_LOAD_SKIPPED", { fragment: fragmentPath });
  }
})('experimentation')
} else {
  ((fragmentPath) => {
  if (window.newrelic) {
    // eslint-disable-next-line no-undef
    newrelic.addPageAction("ESI_LOAD", { fragment: fragmentPath });
  }
})('experimentation')
}
</script>


